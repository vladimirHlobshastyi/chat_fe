{
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": "./",
    "paths": {
      "@utils/*": [
        "src/utils/*"
      ],
      "@ui/*": [
        "src/ui/*"
      ],
      "@forms/*": [
        "src/forms/*"
      ],
      "@features/*": [
        "src/features/*"
      ]
    },
    "moduleResolution": "bundler",
    "module": "ESNext",
    "types": [
      "vite/client"
    ],
    "strictNullChecks": true
  }
}