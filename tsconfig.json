{
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@api/*": [
        "./src/api/*"
      ],
      "@queries/*": [
        "./src/api/queries/*"
      ],
      "@components/*": [
        "./src/components/*"
      ],
      "@pages/*": [
        "./src/pages/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@types/*": [
        "./src/types/*"
      ],
      "@utils/*": [
        "./src/utils/*"
      ],
      "@routes/*": [
        "./src/routes/*"
      ],
      "@hooks/*": [
        "./src/hooks/*"
      ],
      "@features/*": [
        "./src/features/*"
      ],
      "@providers/*": [
        "./src/providers/*"
      ],
    },
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2015",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "types": [
      "vite/client"
    ],
    "strictNullChecks": true
  }
}